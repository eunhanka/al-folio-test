{%- comment -%}
  Self-contained hero for the About page.
{%- endcomment -%}

<style>
#eh-hero { margin: 0 0 2rem; }
#eh-hero .eh-top { display: flex; align-items: flex-start; gap: 1.6rem; }
#eh-hero .eh-photo { flex-shrink: 0; width: 160px; height: auto; border-radius: 12px; border: 0.5px solid var(--global-divider-color); object-fit: cover; }
#eh-hero .eh-intro { min-width: 0; }
#eh-hero .eh-eyebrow { font-size: 0.8rem; color: var(--global-text-color-light); margin: 0 0 0.4rem; }
#eh-hero .eh-name { font-size: 2rem; font-weight: 500; line-height: 1.1; margin: 0 0 0.6rem; color: var(--global-text-color); }
#eh-hero .eh-rule { width: 34px; height: 3px; background: var(--global-theme-color); border-radius: 2px; margin: 0 0 0.9rem; }
#eh-hero .eh-summary { font-size: 1rem; line-height: 1.6; max-width: 42rem; color: var(--global-text-color); margin: 0 0 0.7rem; }
#eh-hero .eh-vision { font-size: 0.92rem; line-height: 1.6; max-width: 42rem; color: var(--global-text-color-light); border-left: 2px solid var(--global-theme-color); padding-left: 0.8rem; margin: 0 0 1.1rem; }
#eh-hero .eh-links, #eh-hero .eh-secondary { display: flex; flex-wrap: wrap; gap: 1.1rem; margin: 0 0 0.4rem; }
#eh-hero .eh-links a, #eh-hero .eh-secondary a { display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; color: var(--global-text-color); text-decoration: none; }
#eh-hero .eh-links a i, #eh-hero .eh-secondary a i { font-size: 1rem; color: var(--global-theme-color); }
#eh-hero .eh-links a:hover, #eh-hero .eh-secondary a:hover { color: var(--global-theme-color); }
#eh-hero .eh-secondary { margin-top: 1rem; padding-top: 0.9rem; border-top: 0.5px solid var(--global-divider-color); }
#eh-hero .eh-foundation { display: flex; align-items: center; gap: 0.6rem; margin: 1.4rem 0 0.8rem; }
#eh-hero .eh-foundation-label, #eh-hero .eh-foundation-hint { font-size: 0.78rem; color: var(--global-text-color-light); }
#eh-hero .eh-foundation-pill { font-size: 0.82rem; font-weight: 500; color: var(--global-text-color); background: var(--global-bg-color); border: 0.5px solid var(--global-divider-color); border-radius: 999px; padding: 0.2rem 0.8rem; }
#eh-hero .eh-foundation-line { flex: 1; height: 0.5px; background: var(--global-divider-color); }
#eh-hero .eh-focus { display: grid; grid-template-columns: 0.95fr 1.05fr; gap: 1.1rem; align-items: start; }
#eh-hero .eh-pillars { display: flex; flex-direction: column; gap: 0.5rem; }
#eh-hero .eh-kw { display: flex; align-items: center; gap: 0.65rem; width: 100%; text-align: left; padding: 0.7rem 0.8rem; border: 0.5px solid var(--global-divider-color); border-radius: 8px; background: var(--global-bg-color); color: var(--global-text-color); cursor: pointer; transition: border-color 0.15s, background 0.15s; }
#eh-hero .eh-kw i { font-size: 1.1rem; color: var(--global-theme-color); flex-shrink: 0; }
#eh-hero .eh-kw .eh-kt { font-size: 0.86rem; font-weight: 500; }
#eh-hero .eh-kw:hover, #eh-hero .eh-kw.active { border-color: var(--global-theme-color); }
#eh-hero .eh-papers { background: var(--global-card-bg-color, var(--global-bg-color)); border: 0.5px solid var(--global-divider-color); border-radius: 8px; padding: 0.2rem 1rem; min-height: 13rem; }
#eh-hero .eh-paper { display: block; padding: 0.65rem 0; border-bottom: 0.5px solid var(--global-divider-color); text-decoration: none; }
#eh-hero .eh-paper:last-child { border-bottom: 0; }
#eh-hero .eh-paper .eh-pt { font-size: 0.82rem; line-height: 1.45; margin: 0 0 0.25rem; color: var(--global-text-color); }
#eh-hero .eh-paper .eh-pv { font-size: 0.76rem; margin: 0; color: var(--global-text-color-light); }
#eh-hero .eh-paper .eh-pv em { font-style: normal; color: var(--global-theme-color); }
#eh-hero .eh-paper:hover .eh-pt { color: var(--global-theme-color); }
@media (max-width: 768px) { #eh-hero .eh-focus { grid-template-columns: 1fr; } }
@media (max-width: 576px) {
  #eh-hero .eh-top { flex-direction: column; align-items: center; text-align: center; }
  #eh-hero .eh-rule { margin-left: auto; margin-right: auto; }
  #eh-hero .eh-vision { border-left: 0; padding-left: 0; }
  #eh-hero .eh-links { justify-content: center; }
}
</style>

<div id="eh-hero">
  <div class="eh-top">
    <img class="eh-photo" src="{{ '/assets/img/prof_pic.jpg' | relative_url }}" alt="Portrait of Eunhan Ka" width="160" height="206" loading="eager">
    <div class="eh-intro">
      <p class="eh-eyebrow">Postdoctoral researcher · Purdue University</p>
      <h1 class="eh-name">Eunhan Ka</h1>
      <div class="eh-rule"></div>
      <p class="eh-summary">I develop physics-informed and data-driven methods to model, estimate, and secure traffic dynamics across large-scale transportation networks.</p>
      <p class="eh-vision">{{ site.data.research.vision }}</p>
      <div class="eh-links">
        <a href="mailto:{{ site.email }}"><i class="ti ti-mail"></i>Email</a>
        <a href="{{ site.scholar_url }}" target="_blank" rel="noopener"><i class="ti ti-school"></i>Google Scholar</a>
        <a href="https://github.com/{{ site.github_username }}" target="_blank" rel="noopener"><i class="ti ti-brand-github"></i>GitHub</a>
      </div>
    </div>
  </div>

  <div class="eh-foundation">
    <span class="eh-foundation-label">Common foundation</span>
    <span class="eh-foundation-pill">{{ site.data.research.common_foundation }}</span>
    <span class="eh-foundation-line"></span>
    <span class="eh-foundation-hint">hover a focus area</span>
  </div>

  <div class="eh-focus">
    <div class="eh-pillars" role="tablist" aria-label="Research focus areas">
      {%- for p in site.data.research.pillars -%}
      <button class="eh-kw{% if forloop.first %} active{% endif %}" data-k="{{ p.id }}" role="tab" aria-selected="{% if forloop.first %}true{% else %}false{% endif %}">
        <i class="ti {{ p.icon }}" aria-hidden="true"></i>
        <span class="eh-kt">{{ p.name }}</span>
      </button>
      {%- endfor -%}
    </div>
    <div class="eh-papers" id="eh-papers" aria-live="polite"></div>
  </div>

  <div class="eh-secondary">
    <a href="{{ '/research/' | relative_url }}"><i class="ti ti-users"></i>Mentoring</a>
    <a href="https://github.com/{{ site.github_username }}" target="_blank" rel="noopener"><i class="ti ti-code"></i>Code &amp; data</a>
    <a href="{{ '/talks/' | relative_url }}"><i class="ti ti-presentation"></i>Talks</a>
  </div>
</div>

<script id="eh-research-data" type="application/json">
{
  {%- for p in site.data.research.pillars -%}
  "{{ p.id }}": [
    {%- assign keys = p.papers -%}
    {%- for key in keys -%}
      {%- assign entry = site.data.eh_papers_index[key] -%}
      {"t": {{ entry.title | jsonify }}, "v": {{ entry.venue | jsonify }}, "y": {{ entry.year | jsonify }}, "url": {{ entry.url | jsonify }}}{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
}
</script>

<script>
(function () {
  var dataEl = document.getElementById("eh-research-data");
  var box = document.getElementById("eh-papers");
  if (!dataEl || !box) return;
  var data;
  try { data = JSON.parse(dataEl.textContent); } catch (e) { return; }
  var buttons = document.querySelectorAll("#eh-hero .eh-kw");
  function render(key) {
    var list = data[key] || [];
    box.innerHTML = list.map(function (p) {
      var inner = '<p class="eh-pt">' + p.t + '</p><p class="eh-pv"><em>' + p.v + '</em> &middot; ' + p.y + '</p>';
      return p.url ? '<a class="eh-paper" href="' + p.url + '">' + inner + '</a>' : '<div class="eh-paper">' + inner + '</div>';
    }).join("");
  }
  function activate(btn) {
    buttons.forEach(function (b) { b.classList.remove("active"); b.setAttribute("aria-selected", "false"); });
    btn.classList.add("active"); btn.setAttribute("aria-selected", "true");
    render(btn.dataset.k);
  }
  buttons.forEach(function (btn) {
    btn.addEventListener("mouseenter", function () { activate(btn); });
    btn.addEventListener("focus", function () { activate(btn); });
    btn.addEventListener("click", function () { activate(btn); });
  });
  if (buttons.length) render(buttons[0].dataset.k);
})();
</script>