{%- comment -%}
  Self-contained hero for the About page.
{%- endcomment -%}

<style>
  #eh-hero {
    margin: 0 0 1.5rem;
  }
  #eh-hero .eh-top {
    display: flex;
    align-items: flex-start;
    gap: 1.8rem;
  }
  #eh-hero .eh-photo {
    flex-shrink: 0;
    width: 180px;
    height: auto;
    border-radius: 12px;
    border: 0.5px solid var(--global-divider-color);
    object-fit: cover;
  }
  #eh-hero .eh-intro {
    min-width: 0;
  }
  #eh-hero .eh-name {
    font-size: 2.8rem;
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 0.25rem;
    color: var(--global-text-color);
  }
  #eh-hero .eh-title {
    font-size: 1.1rem;
    font-weight: 400;
    line-height: 1.3;
    color: var(--global-text-color-light);
    margin: 0 0 0.9rem;
  }
  #eh-hero .eh-rule {
    width: 40px;
    height: 3px;
    background: var(--global-theme-color);
    border-radius: 2px;
    margin: 0 0 1rem;
  }
  #eh-hero .eh-summary {
    font-size: 1.2rem;
    line-height: 1.6;
    max-width: 44rem;
    color: var(--global-text-color);
    margin: 0 0 0.8rem;
  }
  #eh-hero .eh-vision {
    font-size: 1.05rem;
    line-height: 1.6;
    max-width: 44rem;
    color: var(--global-text-color-light);
    border-left: 3px solid var(--global-theme-color);
    padding-left: 0.9rem;
    margin: 0 0 1.2rem;
  }
  #eh-hero .eh-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.4rem;
    margin: 0;
  }
  #eh-hero .eh-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--global-text-color-light);
    text-decoration: none;
    line-height: 1;
  }
  #eh-hero .eh-links a i {
    font-size: 1.5rem;
    transition: color 0.15s;
  }
  #eh-hero .eh-links a:hover {
    color: var(--global-theme-color);
  }
  #eh-hero .eh-links a:hover i {
    color: var(--global-theme-color);
  }
  #eh-hero .eh-bio {
    margin: 2.2rem 0 0;
  }
  #eh-hero .eh-bio p {
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--global-text-color);
    margin: 0 0 1rem;
  }
  #eh-hero .eh-education {
    margin: 2.2rem 0 0;
  }
  #eh-hero .eh-research {
    margin: 2.2rem 0 0;
  }
  #eh-hero .eh-section-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--global-text-color);
    margin: 0 0 0.8rem;
    padding-bottom: 0.3rem;
    border-bottom: 2px solid var(--global-theme-color);
    display: inline-block;
  }
  #eh-hero .eh-edu-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  #eh-hero .eh-edu-item {
    padding: 0 0 0 0.9rem;
    border-left: 2px solid var(--global-divider-color);
    margin: 0 0 0.9rem;
  }
  #eh-hero .eh-edu-item:last-child {
    margin-bottom: 0;
  }
  #eh-hero .eh-edu-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.2rem 0.6rem;
  }
  #eh-hero .eh-edu-degree {
    font-weight: 600;
    color: var(--global-theme-color);
  }
  #eh-hero .eh-edu-where {
    color: var(--global-text-color);
  }
  #eh-hero .eh-edu-date {
    margin-left: auto;
    font-size: 0.9rem;
    color: var(--global-text-color-light);
    white-space: nowrap;
  }
  #eh-hero .eh-edu-note {
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--global-text-color-light);
    margin: 0.25rem 0 0;
  }
  #eh-hero .eh-news {
    margin: 2.2rem 0 0;
  }
  #eh-hero .eh-news-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  #eh-hero .eh-news-item {
    display: flex;
    gap: 0.9rem;
    padding: 0.5rem 0;
    border-bottom: 0.5px solid var(--global-divider-color);
    line-height: 1.5;
  }
  #eh-hero .eh-news-item:last-child {
    border-bottom: 0;
  }
  #eh-hero .eh-news-date {
    flex: 0 0 5.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--global-theme-color);
    white-space: nowrap;
  }
  #eh-hero .eh-news-text {
    color: var(--global-text-color);
  }
  #eh-hero .eh-news-text a {
    color: var(--global-text-color);
  }
  #eh-hero .eh-news-text a:hover {
    color: var(--global-theme-color);
  }
  @media (max-width: 576px) {
    #eh-hero .eh-news-item {
      flex-direction: column;
      gap: 0.1rem;
    }
  }
  #eh-hero .eh-foundation {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin: 0 0 0.9rem;
  }
  #eh-hero .eh-foundation-intro {
    font-size: 1rem;
    line-height: 1.5;
    color: var(--global-text-color);
    margin: 0;
  }
  #eh-hero .eh-foundation-hint {
    flex-shrink: 0;
    font-size: 0.85rem;
    color: var(--global-text-color-light);
  }
  #eh-hero .eh-focus {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 1.2rem;
    align-items: start;
  }
  #eh-hero .eh-pillars {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  #eh-hero .eh-kw {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    width: 100%;
    text-align: left;
    padding: 0.85rem 0.95rem;
    border: 0.5px solid var(--global-divider-color);
    border-radius: 8px;
    background: var(--global-bg-color);
    color: var(--global-text-color);
    cursor: pointer;
    transition: border-color 0.15s;
  }
  #eh-hero .eh-kw i {
    font-size: 1.25rem;
    color: var(--global-theme-color);
    flex-shrink: 0;
  }
  #eh-hero .eh-kw .eh-kt {
    font-size: 1rem;
    font-weight: 500;
  }
  #eh-hero .eh-kw:hover,
  #eh-hero .eh-kw.active {
    border-color: var(--global-theme-color);
  }
  #eh-hero .eh-papers {
    background: var(--global-card-bg-color, var(--global-bg-color));
    border: 0.5px solid var(--global-divider-color);
    border-radius: 8px;
    padding: 0.3rem 1.1rem;
    /* Fixed to the tallest pillar (4 papers ~ 410px) so switching focus
       between areas with different paper counts doesn't shift the layout.
       Released on small screens where the panel stacks full-width. */
    min-height: 26rem;
  }
  #eh-hero .eh-paper {
    display: block;
    padding: 0.75rem 0;
    border-bottom: 0.5px solid var(--global-divider-color);
    text-decoration: none;
  }
  #eh-hero .eh-paper:last-child {
    border-bottom: 0;
  }
  #eh-hero .eh-paper .eh-pt {
    font-size: 0.95rem;
    line-height: 1.45;
    margin: 0 0 0.3rem;
    color: var(--global-text-color);
  }
  #eh-hero .eh-paper .eh-pv {
    font-size: 0.85rem;
    margin: 0;
    color: var(--global-text-color-light);
  }
  #eh-hero .eh-paper .eh-pv em {
    font-style: normal;
    color: var(--global-theme-color);
  }
  #eh-hero .eh-paper:hover .eh-pt {
    color: var(--global-theme-color);
  }
  @media (max-width: 768px) {
    #eh-hero .eh-focus {
      grid-template-columns: 1fr;
    }
    /* Stacked layout: the panel sits below the buttons, so a tall fixed
       min-height would leave a large gap. Release it on small screens. */
    #eh-hero .eh-papers {
      min-height: 0;
    }
  }
  @media (max-width: 576px) {
    #eh-hero .eh-top {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    #eh-hero .eh-rule {
      margin-left: auto;
      margin-right: auto;
    }
    #eh-hero .eh-vision {
      border-left: 0;
      padding-left: 0;
    }
    #eh-hero .eh-links {
      justify-content: center;
    }
  }
</style>

<div id="eh-hero">
  <div class="eh-top">
    <img class="eh-photo" src="{{ '/assets/img/prof_pic.jpg' | relative_url }}" alt="Portrait of Eunhan Ka" width="180" height="232" loading="eager">
    <div class="eh-intro">
      <h1 class="eh-name">Eunhan Ka</h1>
      <p class="eh-title">Postdoctoral Researcher · Purdue University</p>
      <div class="eh-rule"></div>
      <p class="eh-summary">
        I develop physics-informed and data-driven methods to model, estimate, and secure traffic dynamics across large-scale transportation networks.
      </p>
      <p class="eh-vision">{{ site.data.research.vision }}</p>
      <div class="eh-links">
        <a href="mailto:{{ site.email }}" title="Email" aria-label="Email"><i class="fa-solid fa-envelope" aria-hidden="true"></i></a>
        <a href="{{ site.scholar_url }}" target="_blank" rel="noopener" title="Google Scholar" aria-label="Google Scholar"
          ><i class="ai ai-google-scholar" aria-hidden="true"></i
        ></a>
        <a href="https://github.com/{{ site.github_username }}" target="_blank" rel="noopener" title="GitHub" aria-label="GitHub"
          ><i class="fa-brands fa-github" aria-hidden="true"></i
        ></a>
        <a href="https://orcid.org/0000-0003-0954-8075" target="_blank" rel="noopener" title="ORCID" aria-label="ORCID"
          ><i class="ai ai-orcid" aria-hidden="true"></i
        ></a>
      </div>
    </div>
  </div>

  <div class="eh-bio">
    <p>
      I am a postdoctoral researcher in the Lyles School of Civil and Construction Engineering at Purdue University, where I completed my Ph.D. under
      the supervision of Dr. Satish V. Ukkusuri. My dissertation,
      <em>Physics-Informed Neural Networks for Secure Connected and Autonomous Traffic Modeling</em>, develops methods at the intersection of traffic
      flow theory, machine learning, and behavioral modeling.
    </p>
    <p>
      I study how transportation networks behave under disruption and adversarial manipulation — with emphasis on network resilience, transportation
      cybersecurity, and large-scale state estimation — and how reliable estimation and decision support can be maintained under uncertainty.
    </p>
    <p>Before Purdue, I earned my B.S. and M.S. in Civil and Environmental Engineering from Seoul National University.</p>
  </div>

  <section class="eh-education" aria-label="Education">
    <h2 class="eh-section-title">Education</h2>
    <ul class="eh-edu-list">
      {%- for e in site.data.research.education -%}
        <li class="eh-edu-item">
          <div class="eh-edu-head">
            <span class="eh-edu-degree">{{ e.degree }}</span>
            <span class="eh-edu-where">{{ e.field }}, {{ e.institution }}</span>
            <span class="eh-edu-date">{{ e.date }}</span>
          </div>
          {%- if e.note %}
            <p class="eh-edu-note">{{ e.note }}</p>
          {% endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </section>

  <section class="eh-research" aria-label="Research focus areas">
    <h2 class="eh-section-title">Research</h2>
    <div class="eh-foundation">
      <p class="eh-foundation-intro">Four focus areas, built on a shared foundation in {{ site.data.research.common_foundation | downcase }}.</p>
      <span class="eh-foundation-hint">hover a focus area</span>
    </div>

    <div class="eh-focus">
      <div class="eh-pillars" role="tablist" aria-label="Research focus areas">
        {%- for p in site.data.research.pillars -%}
          <button
            class="eh-kw{% if forloop.first %} active{% endif %}"
            data-k="{{ p.id }}"
            role="tab"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          >
            <i class="{{ p.icon }}" aria-hidden="true"></i>
            <span class="eh-kt">{{ p.name }}</span>
          </button>
        {%- endfor -%}
      </div>
      <div class="eh-papers" id="eh-papers" aria-live="polite"></div>
    </div>
  </section>

  {%- assign eh_news = site.news | sort: 'date' | reverse -%}
  {%- if eh_news != blank -%}
    <section class="eh-news" aria-label="Recent news">
      <h2 class="eh-section-title">News</h2>
      <ul class="eh-news-list">
        {%- for item in eh_news limit: 7 -%}
          <li class="eh-news-item">
            <span class="eh-news-date">{{ item.date | date: '%b %Y' }}</span>
            <span class="eh-news-text">
              {%- if item.inline -%}
                {{ item.content | markdownify | remove: '<p>' | remove: '</p>' | strip }}
              {%- else -%}
                <a href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {%- endif -%}
            </span>
          </li>
        {%- endfor -%}
      </ul>
    </section>
  {%- endif -%}
</div>

<script id="eh-research-data" type="application/json">
  {
    {%- for p in site.data.research.pillars -%}
    "{{ p.id }}": [
      {%- assign keys = p.papers -%}
      {%- for key in keys -%}
        {%- assign entry = site.data.eh_papers_index[key] -%}
        {"t": {{ entry.title | jsonify }}, "v": {{ entry.venue | jsonify }}, "y": {{ entry.year | jsonify }}, "url": {{ entry.url | jsonify }}}{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  }
</script>

<script>
  (function () {
    var dataEl = document.getElementById('eh-research-data');
    var box = document.getElementById('eh-papers');
    if (!dataEl || !box) return;
    var data;
    try {
      data = JSON.parse(dataEl.textContent);
    } catch (e) {
      return;
    }
    var buttons = document.querySelectorAll('#eh-hero .eh-kw');
    function render(key) {
      var list = data[key] || [];
      box.innerHTML = list
        .map(function (p) {
          var inner = '<p class="eh-pt">' + p.t + '</p><p class="eh-pv"><em>' + p.v + '</em> &middot; ' + p.y + '</p>';
          return p.url ? '<a class="eh-paper" href="' + p.url + '">' + inner + '</a>' : '<div class="eh-paper">' + inner + '</div>';
        })
        .join('');
    }
    function activate(btn) {
      buttons.forEach(function (b) {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      render(btn.dataset.k);
    }
    buttons.forEach(function (btn) {
      btn.addEventListener('mouseenter', function () {
        activate(btn);
      });
      btn.addEventListener('focus', function () {
        activate(btn);
      });
      btn.addEventListener('click', function () {
        activate(btn);
      });
    });
    if (buttons.length) render(buttons[0].dataset.k);
  })();
</script>
